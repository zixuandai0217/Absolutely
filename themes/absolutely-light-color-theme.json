    "terminal.foreground": "#2d2d2b",
    "terminalCursor.background": "#f9f9f7",
    "terminalCursor.foreground": "#cc7d5e",
    "terminal.ansiBlack": "#2d2d2b",
    "terminal.ansiRed": "#ff5f38",
    "terminal.ansiGreen": "#00c853",
    "terminal.ansiYellow": "#bc7559",
    "terminal.ansiBlue": "#5f7fbe",
    "terminal.ansiMagenta": "#cc7d5e",
    "terminal.ansiCyan": "#3b7f68",
    "terminal.ansiWhite": "#f4f4f2",
    "terminal.ansiBrightBlack": "#939391",
    "terminal.ansiBrightRed": "#ff5f38",
    "terminal.ansiBrightGreen": "#00c853",
    "terminal.ansiBrightYellow": "#d28e73",
    "terminal.ansiBrightBlue": "#7394d2",
    "terminal.ansiBrightMagenta": "#dc9a80",
    "terminal.ansiBrightCyan": "#55a98d",
    "terminal.ansiBrightWhite": "#ffffff"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "comment.line",
        "comment.block"
      ],
      "settings": {
        "foreground": "#939391"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.regexp",
        "constant.other.symbol",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#00c853"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#ff5f38"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator",
        "keyword.other",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.definition.keyword"
      ],
      "settings": {
        "foreground": "#ff5f38"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.enum",
        "entity.name.interface",
        "entity.name.struct",
        "entity.other.inherited-class",
        "support.class",
        "support.constant",
        "support.type",
        "support.type.primitive"
      ],
      "settings": {
        "foreground": "#bc7559"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "entity.name.function.constructor",
        "support.function",
        "support.function.builtin",
        "variable.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#2d2d2b"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter",
        "meta.object-literal.key",
        "support.variable.property",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#2d2d2b"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.type.property-name",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#bc7559"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#ff5f38"
      }
    }
  ],
  "semanticTokenColors": {
    "boolean": "#ff5f38",
    "class": "#bc7559",
    "comment": "#939391",
    "decorator": "#bc7559",
    "enum": "#bc7559",
    "enumMember": "#bc7559",
    "function": "#2d2d2b",
    "interface": "#bc7559",
    "keyword": "#ff5f38",
    "macro": "#ff5f38",
    "method": "#2d2d2b",
    "namespace": "#bc7559",
    "number": "#ff5f38",
    "operator": "#ff5f38",
    "parameter": "#2d2d2b",
    "property": "#2d2d2b",
    "regexp": "#00c853",
    "string": "#00c853",
    "struct": "#bc7559",
    "type": "#bc7559",
    "variable": "#2d2d2b"
  }
}
