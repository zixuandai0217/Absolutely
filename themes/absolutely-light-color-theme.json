    "editorGroupHeader.tabsBorder": "#e4e1dc",
    "editorGroupHeader.noTabsBackground": "#f4f4f2",
    "tab.activeBackground": "#f9f9f7",
    "tab.activeBorder": "#f9f9f7",
    "tab.activeBorderTop": "#cc7d5e",
    "tab.activeForeground": "#2d2d2b",
    "tab.border": "#e4e1dc",
    "tab.inactiveBackground": "#f4f4f2",
