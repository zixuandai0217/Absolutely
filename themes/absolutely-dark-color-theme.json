    "terminalCursor.background": "#2d2d2b",
    "terminalCursor.foreground": "#cc7d5e",
    "terminal.ansiBlack": "#2d2d2b",
    "terminal.ansiRed": "#ff5f38",
    "terminal.ansiGreen": "#00c853",
    "terminal.ansiYellow": "#d28e73",
    "terminal.ansiBlue": "#7394d2",
    "terminal.ansiMagenta": "#cc7d5e",
    "terminal.ansiCyan": "#55a98d",
    "terminal.ansiWhite": "#f9f9f7",
    "terminal.ansiBrightBlack": "#939391",
    "terminal.ansiBrightRed": "#ff5f38",
    "terminal.ansiBrightGreen": "#00c853",
    "terminal.ansiBrightYellow": "#e6aa8e",
    "terminal.ansiBrightBlue": "#91ade4",
    "terminal.ansiBrightMagenta": "#dc9a80",
    "terminal.ansiBrightCyan": "#78c9ae",
    "terminal.ansiBrightWhite": "#ffffff"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "comment.line",
        "comment.block"
      ],
      "settings": {
        "foreground": "#b2b2b0"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.regexp",
        "constant.other.symbol",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#00c853"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#ff5f38"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator",
        "keyword.other",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.definition.keyword"
      ],
      "settings": {
        "foreground": "#ff5f38"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.enum",
        "entity.name.interface",
        "entity.name.struct",
        "entity.other.inherited-class",
        "support.class",
        "support.constant",
        "support.type",
        "support.type.primitive"
      ],
      "settings": {
        "foreground": "#d28e73"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "entity.name.function.constructor",
        "support.function",
        "support.function.builtin",
        "variable.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#f9f9f7"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter",
        "meta.object-literal.key",
        "support.variable.property",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#f9f9f7"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.type.property-name",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#d28e73"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#ff5f38"
      }
    }
  ],
  "semanticTokenColors": {
    "boolean": "#ff5f38",
    "class": "#d28e73",
    "comment": "#b2b2b0",
    "decorator": "#d28e73",
    "enum": "#d28e73",
    "enumMember": "#d28e73",
    "function": "#f9f9f7",
    "interface": "#d28e73",
    "keyword": "#ff5f38",
    "macro": "#ff5f38",
    "method": "#f9f9f7",
    "namespace": "#d28e73",
    "number": "#ff5f38",
    "operator": "#ff5f38",
    "parameter": "#f9f9f7",
    "property": "#f9f9f7",
    "regexp": "#00c853",
    "string": "#00c853",
    "struct": "#d28e73",
    "type": "#d28e73",
    "variable": "#f9f9f7"
  }
}
